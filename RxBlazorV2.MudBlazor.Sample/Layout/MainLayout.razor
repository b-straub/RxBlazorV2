@using RxBlazorV2.MudBlazor.Components.Razor
@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer"
                       aria-label="Toggle navigation" />
        @* Long title only above sm — narrow viewports get a compact label so the AppBar's
           right-side icons (GitHub link + status badges) always fit without clipping. *@
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudText Typo="Typo.h6" Class="ml-3">RxBlazorV2.MudBlazor Sample</MudText>
        </MudHidden>
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudText Typo="Typo.h6" Class="ml-3">RxBlazorV2</MudText>
        </MudHidden>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Inherit"
                       Href="https://github.com/b-straub/RxBlazorV2" Target="_blank" />
        <StatusDisplay ShowMessageSource="false" GroupMessagesBySeverity="false" MessageMessageMode="StatusMessageMode.Single"/>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Variant="@DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Md"
               Elevation="1">
        <MudNavMenu>
            @* Hrefs without a leading slash so they resolve relative to <base href="..."> —
               this works both locally (base = "/") and deployed (base = "/RxBlazorV2/mudblazor/").
               An absolute "/sortable" would otherwise route to the host root and 404. *@
            <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.SmartButton">
                Buttons
            </MudNavLink>
            <MudNavLink Href="sortable" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.SwapVert">
                Sortable + Swipeout
            </MudNavLink>
            <MudNavLink Href="contacts" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Group">
                Contact groups
            </MudNavLink>
            <MudNavLink Href="notifications" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.NotificationsActive">
                Notifications
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code
{
    // Drawer starts closed: on Md+ Variant.Responsive will switch it to persistent — the user
    // taps the menu icon once. On smaller viewports a closed-by-default temporary drawer avoids
    // the navigation overlay covering the page on first load.
    private bool _drawerOpen;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
